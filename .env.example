# Required for both stdio and HTTP transports
GETMNEMO_API_URL=https://api.mnemohq.com
GETMNEMO_API_KEY=
GETMNEMO_WORKSPACE_ID=

# Tenant boundary (REQUIRED) — the container every tool call is scoped to.
# Supplied by the developer/operator at startup; the model can NEVER set it.
# Use the simple tag form...
GETMNEMO_CONTAINER_TAG=user:jane
# ...OR the structured-scope form (both type and id required if used):
# GETMNEMO_SCOPE_TYPE=user
# GETMNEMO_SCOPE_ID=jane

# HTTP transport only
PORT=8787
